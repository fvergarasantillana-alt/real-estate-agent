{
  "version": 2,
  "builds": [
    { "src": "app.py", "use": "@vercel/python", "config": { "includeFiles": ["public/**", "api/**"] } },
    { "src": "public/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/static/(.*)", "dest": "/public/static/$1" },
    { "src": "/(.*)", "dest": "app.py" }
  ]
}
